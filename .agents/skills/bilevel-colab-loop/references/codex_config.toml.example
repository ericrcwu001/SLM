# Example ~/.codex/config.toml for running the bilevel-colab-loop autonomously.
# Merge these keys into your existing ~/.codex/config.toml — do NOT blindly overwrite it.
# Verify the skill is discovered with `/skills` and any MCP with `/mcp`. Flag spellings
# (--full-auto / --dangerously-bypass-approvals-and-sandbox / --sandbox) vary by version —
# confirm with `codex --help`. Computer Use is a ChatGPT DESKTOP-APP plugin (Work/Codex plan,
# macOS Screen-Recording + Accessibility perms), NOT the CLI — grant it there for "Run All".

model = "gpt-5.5"
model_reasoning_effort = "high"

# Autonomy for the long loop (the engine + bridge guard correctness):
approval_policy = "never"        # non-interactive; the loop must not block on prompts
sandbox_mode = "workspace-write" # raise to "danger-full-access" only if HF/Colab network needs it

# The loop touches the network (HF pushes/pulls) and writes adapters/run-state.
[features]
# multi_agent = true   # optional; not required — the engine owns loop control

# If you drive Colab via a desktop-automation MCP instead of the ChatGPT app's Computer Use,
# configure it here (Playwright MCP is BROWSER-only and will not drive the desktop Cursor window):
# [mcp_servers.desktop]
# command = "npx"
# args = ["-y", "<a-verified-desktop-automation-mcp>"]
